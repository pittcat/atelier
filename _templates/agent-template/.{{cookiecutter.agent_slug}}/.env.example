# {{ cookiecutter.agent_pascal }} —— 环境变量模板
# 复制为 .env 后填入真实值。

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_replace_me
LANGSMITH_PROJECT=atelier-{{ cookiecutter.agent_slug }}

ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-replace-me

ATELIER_DEFAULT_MODEL={{ cookiecutter.model_default }}
ATELIER_SUBAGENT_MODEL={{ cookiecutter.model_subagent }}

{% if cookiecutter.checkpointer_kind == "postgres" -%}
ATELIER_CHECKPOINTER_URL=postgresql://user:pass@localhost:5432/atelier
{% endif %}
{% if cookiecutter.enable_interrupt == "yes" -%}
ATELIER_INTERRUPT_DEFAULT=true
{% endif %}
