LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_replace_me
LANGSMITH_PROJECT=atelier-code-writer

ANTHROPIC_API_KEY=sk-ant-replace-me

ATELIER_DEFAULT_MODEL=claude-opus-4-8
ATELIER_SUBAGENT_MODEL=claude-haiku-4-5-20251001

ATELIER_INTERRUPT_DEFAULT=true

# Skills（项目级，硬规矩 8）：
#   - ./skills/ 始终加载；可 ATELIER_LOCAL_SKILLS_DIR=path 覆盖（必须项目内）
#   - GitHub 仓库：ATELIER_SKILLS_GITHUB=owner/repo@ref
#   - 绝不读取 ~/.claude/skills、CLAUDE_CODE_SKILLS_DIR 等全局配置

# MCP（项目级，硬规矩 8；默认关闭；要开改为 1）：
ATELIER_MCP_DISABLED=0
ATELIER_MCP_GITHUB=0
ATELIER_MCP_DOCS=0
ATELIER_MCP_FILESYSTEM=0
# GitHub token（开 ATELIER_MCP_GITHUB=1 时必填）：
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Checkpointer：本示例默认 MemorySaver；要切 Postgres：
# ATELIER_CHECKPOINTER_URL=postgresql://user:pass@localhost:5432/atelier
