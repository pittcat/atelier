LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_replace_me
LANGSMITH_PROJECT=atelier-modem-log-analyzer

# ============================================================
# LLM Provider — 三种常见接法任选其一
# ============================================================

# (A) 官方 Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# (B) Minimax / 其他 Anthropic 兼容三方（与 code-writer / compound-builder 对齐）
# ANTHROPIC_API_KEY=<paste-your-minimax-key>
ANTHROPIC_AUTH_TOKEN=<paste-your-minimax-key>
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M3

ATELIER_DEFAULT_MODEL=MiniMax-M3[1M]
ATELIER_SUBAGENT_MODEL=MiniMax-M3

ATELIER_INTERRUPT_DEFAULT=true

# Skills（项目级，硬规矩 8）：
#   - ./skills/ 始终加载；可 MODEM_LOG_ANALYZER_LOCAL_SKILLS_DIR=path 覆盖（必须项目内）
#   - GitHub 仓库：MODEM_LOG_ANALYZER_SKILLS_GITHUB=owner/repo@ref
#   - 绝不读取 ~/.claude/skills、CLAUDE_CODE_SKILLS_DIR 等全局配置

# MCP（项目级，硬规矩 8；默认关闭；要开改为 1）：
MODEM_LOG_ANALYZER_MCP_DISABLED=1

# Checkpointer：本示例默认 MemorySaver；要切 Postgres：
# ATELIER_CHECKPOINTER_URL=postgresql://user:pass@localhost:5432/atelier

# ---- 项目级 ModemCLI 命令知识 ----
# 启动时由 analysis_service 加载；可重写为绝对路径
MODEM_LOG_ANALYZER_COMMAND_CATALOG=knowledge/modemcli_commands.yaml