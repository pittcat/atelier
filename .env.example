# Atelier 全仓统一 .env.example
# 复制为 .env 后填入具体值；各 Agent 子目录也可单独放自己的 .env，重叠 key 会被子目录覆盖。

# =====================================================
# LangSmith (Observability) — 必填
# =====================================================
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_replace_me
LANGSMITH_PROJECT=atelier-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =====================================================
# LLM Provider — 至少填一个
# =====================================================
ANTHROPIC_API_KEY=sk-ant-replace-me
# OPENAI_API_KEY=sk-replace-me
# GOOGLE_API_KEY=replace-me

# =====================================================
# 默认模型（main agent 用）
# =====================================================
ATELIER_DEFAULT_MODEL=claude-opus-4-8
ATELIER_SUBAGENT_MODEL=claude-haiku-4-5-20251001

# =====================================================
# Checkpointer（跨 Agent 实例共享状态）
# =====================================================
# 默认空 = 用 MemorySaver；填了 = PostgresSaver
# ATELIER_CHECKPOINTER_URL=postgresql://user:pass@localhost:5432/atelier

# =====================================================
# Gateway（gateway/api 用）
# =====================================================
GATEWAY_PORT=8080
GATEWAY_AUTH_TOKEN=replace-with-strong-random-string
GATEWAY_ALLOWED_ORIGINS=http://localhost:3000

# =====================================================
# Operations
# =====================================================
ATELIER_LOG_LEVEL=INFO
ATELIER_INTERRUPT_DEFAULT=true
